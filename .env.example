# Entorno general
APP_ENV=development
LOG_LEVEL=INFO

# Backend
DATABASE_URL=sqlite:///./matchvision.db
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
DATA_ROOT=../data
MODEL_ROOT=../models
SEED_DEMO_DATA=true
RATE_LIMIT_PER_MINUTE=60
MAX_IMPORT_SIZE_MB=100

# PostgreSQL (Docker Compose)
POSTGRES_DB=matchvision
POSTGRES_USER=matchvision
POSTGRES_PASSWORD=matchvision_dev

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

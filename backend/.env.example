APP_ENV=development
DEBUG=true
DATABASE_URL=sqlite:///./matchvision.db
# Produccion: postgresql+psycopg://user:password@postgres:5432/matchvision
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
